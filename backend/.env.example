GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=llama-3.3-70b-versatile

DATABASE_URL=postgresql://user:password@localhost:5432/tef_chatbot

CHROMA_PERSIST_DIR=./chroma_data

FAQ_DATA_DIR=./faq
KB_DATA_DIR=./knowledgebase
FAQ_COLLECTION_NAME=faqs
KB_COLLECTION_NAME=knowledge_base

FAQ_TOP_K=3
KB_TOP_K=4
FAQ_DISTANCE_THRESHOLD=0.35
KB_DISTANCE_THRESHOLD=0.45
RETRY_LOOSEN_FACTOR=1.4
MAX_LAYER_ATTEMPTS=2

CONFIDENCE_THRESHOLD=0.6
CONFIDENCE_RETRIEVAL_WEIGHT=0.4

SUPPORT_EMAIL=support@example.com
SUPPORT_PHONE=+1-555-0100-000

FRONTEND_ORIGIN=http://localhost:5173
